# Copy this to scripts/.env and fill in your values
# scripts/.env is gitignored

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://bkjqmlwuozgxthsvgjwi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Personal Access Token (for schema migrations)
# Get at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_personal_access_token_here

# ── AI enrichment ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Places API (highly recommended for rich church data) ──
# Get at: https://console.cloud.google.com → Enable "Places API (New)"
# Without this key the scraper falls back to OSM + website scraping only.
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Copy this to scripts/.env and fill in your values
# scripts/.env is gitignored

# Required for --remote flag (targeting deployed function)
SUPABASE_URL=https://bkjqmlwuozgxthsvgjwi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Set on the Supabase function (via: supabase secrets set ANTHROPIC_API_KEY=...)
# Not needed locally if you set them in supabase/functions/.env
ANTHROPIC_API_KEY=your_anthropic_api_key_here
